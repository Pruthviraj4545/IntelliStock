# PostgreSQL Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intellistock_db

# JWT Configuration
# Use 64+ random hex characters for production
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_recommended

# Server Configuration
PORT=5000

# ML Service Authentication
# Must match ML_API_KEY in ml-service/.env
ML_API_KEY=change-me

# Redis Configuration (Optional)
# Enable caching by setting REDIS_URL (e.g., redis://localhost:6379)
# If not set, caching is disabled and the application runs without Redis
# REDIS_URL=redis://localhost:6379
